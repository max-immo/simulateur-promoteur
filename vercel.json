{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/plu",        "dest": "/api/plu.js" },
    { "src": "/api/airtable",   "dest": "/api/airtable.js" },
    { "src": "/api/sheet",      "dest": "/api/sheet.js" },
    { "src": "/admin",          "dest": "/admin.html" },
    { "src": "/admin.html",     "dest": "/admin.html" },
    { "src": "/rapport",        "dest": "/rapport.html" },
    { "src": "/rapport.html",   "dest": "/rapport.html" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
